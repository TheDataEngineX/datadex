# DataDEX Environment Variables
# Copy to .env and fill in values — never commit .env

# Application
APP_NAME=datadex
ENVIRONMENT=dev                   # dev | staging | prod
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                # console | json

# API Server (port 8001)
HOST=0.0.0.0
PORT=8001

# DataEngineX backend connection
DEX_API_URL=http://localhost:8000

# Database (PostgreSQL)
DB_DRIVER=postgresql
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=datadex
DB_USER=datadex
DB_PASSWORD=

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_ENDPOINT_URL=                  # Leave blank for real AWS; set for LocalStack

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Pipeline defaults
PIPELINE_DEFAULT_BATCH_SIZE=1000
PIPELINE_DEFAULT_WATERMARK_COLUMN=updated_at
